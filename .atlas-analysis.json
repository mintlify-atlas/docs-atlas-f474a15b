  "keyFeatures": [
    "Modular hexagonal architecture with strict decoupling",
    "Multiple interchangeable persistence adapters (JPA, JDBC, MongoDB, Elasticsearch)",
    "Framework-agnostic core domain with pure Java",
    "CQRS-inspired repository pattern",
    "Production-ready Spring Boot integration",
    "Comprehensive testing strategies"
  ],
  "publicApiSurface": [
    "POST /api/v1/products - Register a product",
    "GET /api/v1/products - List all products",
    "GET /api/v1/products/{productId} - Get product by ID",
    "POST /api/v1/inventories/inbound - Add stock (inbound movement)",
    "POST /api/v1/inventories/outbound - Remove stock (outbound movement)",
    "GET /api/v1/inventories/{productId} - Get stock balance for product",
    "RegisterProductUseCase - Core use case for product registration",
    "GetProductUseCase - Core use case for product retrieval",
    "RegisterMovementUseCase - Core use case for inventory movements",
    "GetMovementUseCase - Core use case for movement retrieval",
    "ProductCommandRepository - Port for product write operations",
    "ProductQueryRepository - Port for product read operations",
    "InventoryMovementCommandRepository - Port for inventory write operations",
    "InventoryMovementQueryRepository - Port for inventory read operations"
  ]
}
